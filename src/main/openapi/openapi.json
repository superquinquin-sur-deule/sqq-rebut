{
  "openapi" : "3.1.0",
  "components" : {
    "schemas" : {
      "AppConfig" : {
        "required" : [ "staging" ],
        "type" : "object",
        "properties" : {
          "staging" : {
            "type" : "boolean"
          }
        }
      },
      "LocalDate" : {
        "type" : "string",
        "format" : "date",
        "examples" : [ "2022-03-10" ]
      },
      "Motif" : {
        "required" : [ "id", "label" ],
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "integer",
            "format" : "int64"
          },
          "label" : {
            "type" : "string"
          }
        }
      },
      "NewLineRequest" : {
        "type" : "object",
        "properties" : {
          "barcode" : {
            "type" : "string"
          },
          "dlc" : {
            "$ref" : "#/components/schemas/LocalDate"
          },
          "qty" : {
            "type" : "number",
            "format" : "double"
          },
          "type" : {
            "type" : "string"
          },
          "motifId" : {
            "type" : "integer",
            "format" : "int64"
          }
        }
      },
      "Product" : {
        "required" : [ "id", "barcode", "name", "uom", "uomId", "price", "qtyAvailable", "soldByWeight" ],
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "integer",
            "format" : "int64"
          },
          "barcode" : {
            "type" : "string"
          },
          "name" : {
            "type" : "string"
          },
          "rayon" : {
            "type" : "string"
          },
          "uom" : {
            "type" : "string"
          },
          "uomId" : {
            "type" : "integer",
            "format" : "int64"
          },
          "price" : {
            "type" : "number",
            "format" : "double"
          },
          "qtyAvailable" : {
            "type" : "number",
            "format" : "double"
          },
          "soldByWeight" : {
            "type" : "boolean"
          },
          "scannedWeight" : {
            "type" : "number",
            "format" : "double",
            "description" : "Poids (kg) extrait d'un code-barres balance, à pré-remplir"
          }
        }
      },
      "RebutRequest" : {
        "type" : "object",
        "properties" : {
          "lineIds" : {
            "type" : "array",
            "items" : {
              "type" : "integer",
              "format" : "int64"
            }
          }
        }
      },
      "RebutResult" : {
        "required" : [ "created", "dryRun", "lines" ],
        "type" : "object",
        "properties" : {
          "created" : {
            "type" : "integer",
            "format" : "int32"
          },
          "dryRun" : {
            "type" : "boolean"
          },
          "lines" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/ReleveLineDto"
            }
          }
        }
      },
      "ReleveDto" : {
        "required" : [ "date", "lines" ],
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "integer",
            "format" : "int64"
          },
          "date" : {
            "$ref" : "#/components/schemas/LocalDate"
          },
          "lines" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/ReleveLineDto"
            }
          }
        }
      },
      "ReleveLineDto" : {
        "type" : "object",
        "required" : [ "id", "barcode", "name", "type", "qty", "sent" ],
        "properties" : {
          "id" : {
            "type" : "integer",
            "format" : "int64"
          },
          "barcode" : {
            "type" : "string"
          },
          "name" : {
            "type" : "string"
          },
          "rayon" : {
            "type" : "string"
          },
          "uom" : {
            "type" : "string"
          },
          "type" : {
            "type" : "string"
          },
          "dlc" : {
            "$ref" : "#/components/schemas/LocalDate"
          },
          "urgency" : {
            "type" : "string"
          },
          "motifId" : {
            "type" : "integer",
            "format" : "int64"
          },
          "motifLabel" : {
            "type" : "string"
          },
          "qty" : {
            "type" : "number",
            "format" : "double"
          },
          "sent" : {
            "type" : "boolean"
          },
          "scrapRef" : {
            "type" : "string"
          }
        }
      },
      "ReleveSummaryDto" : {
        "required" : [ "id", "date", "lineCount" ],
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "integer",
            "format" : "int64"
          },
          "date" : {
            "$ref" : "#/components/schemas/LocalDate"
          },
          "lineCount" : {
            "type" : "integer",
            "format" : "int64"
          }
        }
      },
      "UpdateLineRequest" : {
        "type" : "object",
        "properties" : {
          "qty" : {
            "type" : "number",
            "format" : "double"
          },
          "motifId" : {
            "type" : "integer",
            "format" : "int64"
          }
        }
      }
    }
  },
  "tags" : [ {
    "name" : "Configuration"
  }, {
    "name" : "Motifs"
  }, {
    "name" : "Produits"
  }, {
    "name" : "Relevé"
  } ],
  "paths" : {
    "/api/config" : {
      "get" : {
        "summary" : "Drapeaux d'environnement exposés au front (bannière staging, etc.)",
        "operationId" : "getConfig",
        "tags" : [ "Configuration" ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/AppConfig"
                }
              }
            }
          }
        }
      }
    },
    "/api/motifs" : {
      "get" : {
        "summary" : "Lister les motifs de rupture (Odoo stock.scrap.origin, hors « DLC Dépassée »)",
        "operationId" : "getMotifs",
        "tags" : [ "Motifs" ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/Motif"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/products/{barcode}" : {
      "get" : {
        "summary" : "Chercher un produit par code-barres (EAN)",
        "operationId" : "getProductByBarcode",
        "tags" : [ "Produits" ],
        "parameters" : [ {
          "name" : "barcode",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "string"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Product"
                }
              }
            }
          }
        }
      }
    },
    "/api/releve" : {
      "get" : {
        "summary" : "Lire le relevé d'une date (défaut : aujourd'hui)",
        "operationId" : "getReleve",
        "tags" : [ "Relevé" ],
        "parameters" : [ {
          "name" : "date",
          "in" : "query",
          "schema" : {
            "type" : "string"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ReleveDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/releve/lines" : {
      "post" : {
        "summary" : "Ajouter une ligne scannée",
        "operationId" : "addLine",
        "tags" : [ "Relevé" ],
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/NewLineRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ReleveLineDto"
                }
              }
            }
          },
          "400" : {
            "description" : "Bad Request"
          }
        }
      }
    },
    "/api/releve/lines/{id}" : {
      "put" : {
        "summary" : "Modifier une ligne (quantité et/ou motif)",
        "operationId" : "updateLine",
        "tags" : [ "Relevé" ],
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "integer",
            "format" : "int64"
          }
        } ],
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/UpdateLineRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ReleveLineDto"
                }
              }
            }
          },
          "400" : {
            "description" : "Bad Request"
          }
        }
      },
      "delete" : {
        "summary" : "Supprimer une ligne",
        "operationId" : "deleteLine",
        "tags" : [ "Relevé" ],
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "integer",
            "format" : "int64"
          }
        } ],
        "responses" : {
          "204" : {
            "description" : "No Content"
          }
        }
      }
    },
    "/api/releve/rebut" : {
      "post" : {
        "summary" : "Envoyer des lignes au rebut (stock.scrap Odoo) — DLC J-0 et/ou pertes selon les ids",
        "operationId" : "sendRebut",
        "tags" : [ "Relevé" ],
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/RebutRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/RebutResult"
                }
              }
            }
          },
          "400" : {
            "description" : "Bad Request"
          }
        }
      }
    },
    "/api/releves" : {
      "get" : {
        "summary" : "Lister les relevés (récent → ancien)",
        "operationId" : "getReleves",
        "tags" : [ "Relevé" ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/ReleveSummaryDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/releves/{id}" : {
      "get" : {
        "summary" : "Lire un relevé par id",
        "operationId" : "getReleveById",
        "tags" : [ "Relevé" ],
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "integer",
            "format" : "int64"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ReleveDto"
                }
              }
            }
          }
        }
      }
    }
  },
  "info" : {
    "title" : "Rebut API",
    "version" : "1.0.0",
    "description" : "API de relevé des DLC et des Pertes de SuperQuinquin"
  },
  "servers" : [ {
    "url" : "http://localhost:8080",
    "description" : "Auto generated value"
  }, {
    "url" : "http://0.0.0.0:8080",
    "description" : "Auto generated value"
  } ]
}